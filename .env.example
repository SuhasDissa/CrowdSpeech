# Admin password hash (bcrypt). Generate with: htpasswd -bnBC 10 "" yourpassword | tr -d ':\n'
# Or use: go run ./cmd/genhash yourpassword
ADMIN_PASSWORD_HASH=$2b$10$examplehashgoeshere...

# PocketBase data directory (used inside container)
PB_DATA_DIR=/app/pb_data

# Port for backend service
PB_PORT=10001
